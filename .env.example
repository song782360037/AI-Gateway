# ==================== AI-Gateway Docker 环境变量配置 ====================
# 复制此文件为 .env 并根据实际环境修改

# 应用端口
APP_PORT=8080

# ==================== 外部 MySQL 配置（默认） ====================
# 连接外部已有的 MySQL 实例
DB_HOST=192.168.1.100
DB_PORT=3306
DB_NAME=ai_gateway
DB_USER=root
DB_PASS=your_mysql_password_here

# ==================== 外部 Redis 配置（默认） ====================
# 连接外部已有的 Redis 实例
REDIS_HOST=192.168.1.100
REDIS_PORT=6379
REDIS_PASS=

# ==================== 本地基础设施端口（仅 docker-compose.infra.yml 使用） ====================
# 当使用本地 MySQL/Redis 容器时，DB_HOST/REDIS_HOST 需改为容器名
# MYSQL_PORT=3306
# REDIS_PORT=6379

# 应用安全配置（32字节hex编码，64个十六进制字符）
GATEWAY_API_KEY_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CSRF Token 签名密钥（Base64编码32字节，可选）
GATEWAY_ADMIN_CSRF_SIGNING_KEY=

# JVM 参数
JAVA_OPTS=-Xms256m -Xmx512m

# Spring Profile
SPRING_PROFILES_ACTIVE=docker